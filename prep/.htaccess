# /prep/.htaccess
# Password protection intentionally REMOVED (Barton's call, 2026-06-26).
# The interview-prep docs are unlinked from the public site and noindexed,
# but are now publicly READABLE by anyone who has the URL (dossiers and
# strategy included). This is private-by-obscurity, not authenticated.
#
# To re-gate later, restore a Basic Auth block here and create a server-only
# password file (kept OUT of the repo so deploys never overwrite it):
#   AuthType Basic
#   AuthName "Interview Prep"
#   AuthUserFile "/home/customer/www/fieldflo.bartosuerte.com/.htpasswd_prep"
#   Require valid-user
# then on the server: htpasswd -c /home/customer/www/fieldflo.bartosuerte.com/.htpasswd_prep barton

# Keep /prep out of search indexes even though it is open.
<IfModule mod_headers.c>
  Header set X-Robots-Tag "noindex, nofollow"
</IfModule>

# No directory listings (so /prep/content/ cannot be browsed).
Options -Indexes
